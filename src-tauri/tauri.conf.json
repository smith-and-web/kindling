{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kindling",
  "version": "1.1.1",
  "identifier": "com.kindlingwriter.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kindling",
        "width": 1600,
        "height": 1000,
        "minWidth": 1360,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src ipc: http://ipc.localhost https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": null,
      "entitlements": "./Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Spark your draft - Bridge the gap between outline and prose",
    "longDescription": "Kindling helps fiction writers go from outline to draft by providing a scaffolded writing environment where scene beats appear as expandable prompts."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/smith-and-web/kindling/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2QUZGOEI1QUYzNjMzNQpSV1ExWS9OYWkvOXFCUFpLZUFaRUpvM0IxZk1jRHJlTHIxbHlUY3lqdFlIeDQ0dWU0TGRxQldWMwo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
